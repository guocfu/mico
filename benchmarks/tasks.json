      "<tool>{\"name\":\"list_files\",\"args\":{\"path\":\".\"}}</tool>",
      "<final>recovered</final>"
    ],
    "workspace_setup": [
      {"path": "hello.txt", "content": "hello world\n"}
    ],
    "assertions": {
      "stop_reason": "final",
      "failure_category": "success",
      "tools_used": ["list_files"],
      "tool_call_summary": {"ok": 1},
      "trace_retry_error_kinds": ["unknown_block"],
