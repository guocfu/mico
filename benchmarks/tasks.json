  {
    "name": "patch_file_denied",
    "description": "patch_file rejected under approval=never",
    "approval_policy": "never",
    "fake_outputs": [
      "<tool>{\"name\":\"patch_file\",\"args\":{\"path\":\"code.py\",\"old_text\":\"old\",\"new_text\":\"new\"}}</tool>",
      "<final>could not patch</final>"
    ],
    "workspace_setup": [
      {"path": "code.py", "content": "old content\n"}
    ],
    "assertions": {
      "stop_reason": "final",
      "failure_category": "success",
      "tools_used": ["patch_file"],
      "tool_call_summary": {"approval_denied": 1},
      "history_contains": ["approval=never"],
      "file_contents": {"code.py": "old content\n"},
      "raw_model_outputs_absent_from_report": true
    }
  },
  {
