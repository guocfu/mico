[
  {
    "name": "list_files_success",
    "description": "list_files returns workspace contents",
    "fake_outputs": [
      "<tool>{\"name\":\"list_files\",\"args\":{\"path\":\".\"}}</tool>",
      "<final>listed files</final>"
    ],
    "workspace_setup": [
      {"path": "hello.txt", "content": "hello world\n"}
    ],
    "assertions": {
      "stop_reason": "final",
      "failure_category": "success",
      "tools_used": ["list_files"],
      "tool_call_summary": {"ok": 1},
      "history_contains": ["hello.txt"],
      "raw_model_outputs_absent_from_report": true
    }
  },
  {
    "name": "read_file_success",
